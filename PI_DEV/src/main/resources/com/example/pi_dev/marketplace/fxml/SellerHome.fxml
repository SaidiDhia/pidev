<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pi_dev.marketplace.Controllers.ProductManagementController"
            stylesheets="@/com/example/pi_dev/marketplace/css/example/pi_dev/marketplace/css/style.css">

    <!-- TOP NAV — Seller only -->
    <top>
        <VBox style="-fx-background-color: #1565C0;">

            <!-- Nav Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT"
                  style="-fx-padding: 12 20; -fx-background-color: #1565C0;">

                <!-- Back to role selection -->
                <Button text="⬅ Home" onAction="#goToRoleSelection"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 14; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Label text="🌿 WonderLust — Seller"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Nav buttons -->
                <Button text="📦 My Orders" onAction="#openOrders"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 16; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Button text="📊 Dashboard" onAction="#openDashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 16; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Button text="➕ Add Product" onAction="#handleAdd"
                        style="-fx-background-color: #FF6F00; -fx-text-fill: white;
                               -fx-background-radius: 20; -fx-padding: 6 16;
                               -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Search and Filter Bar -->
            <HBox spacing="12" alignment="CENTER"
                  style="-fx-padding: 10 20; -fx-background-color: #0D47A1;">

                <TextField fx:id="searchField"
                           promptText="🔍 Search my products..."
                           onKeyReleased="#handleSearch"
                           prefWidth="280"
                           style="-fx-background-radius: 20; -fx-padding: 8 15; -fx-font-size: 13px;"/>

                <ComboBox fx:id="categoryFilter"
                          promptText="📂 All Categories"
                          onAction="#handleFilter"
                          prefWidth="160"
                          style="-fx-background-radius: 20;"/>

                <ComboBox fx:id="typeFilter"
                          promptText="🏷️ All Types"
                          onAction="#handleFilter"
                          prefWidth="140"
                          style="-fx-background-radius: 20;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="My Products Dashboard"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>

        </VBox>
    </top>

    <!-- Products Grid -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true">
            <VBox spacing="20">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <FlowPane fx:id="productFlow" hgap="20" vgap="20"
                          alignment="TOP_LEFT" prefWrapLength="1000"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
