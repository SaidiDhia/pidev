<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.CheckBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.UserFormController" stylesheets="@style.css" prefWidth="400">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Add New User" styleClass="label-title"/>

    <VBox spacing="5">
        <Label text="Full Name"/>
        <TextField fx:id="fullNameField"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Email"/>
        <TextField fx:id="emailField"/>
    </VBox>
    
    <VBox spacing="5">
        <Label text="Phone Number"/>
        <TextField fx:id="phoneField"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Leave blank to keep unchanged (Edit mode)"/>
    </VBox>

    <HBox spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Role"/>
            <ComboBox fx:id="roleComboBox" maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="5" alignment="CENTER_LEFT">
             <Label text="Status"/>
             <CheckBox fx:id="isActiveCheckBox" text="Active"/>
        </VBox>
    </HBox>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="button-secondary"/>
        <Button text="Save" onAction="#handleSave" styleClass="button-primary"/>
    </HBox>
</VBox>