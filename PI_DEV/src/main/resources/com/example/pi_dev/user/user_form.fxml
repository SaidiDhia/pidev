<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="450.0" spacing="25.0" styleClass="card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.Controllers.Users.UserFormController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <Label fx:id="titleLabel" styleClass="text-h2" text="Add New User" />
        
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <javafx.scene.shape.Circle fx:id="profileCircle" radius="40.0" fill="#F3F4F6" stroke="#E5E7EB" />
                <Button onAction="#handleUploadPhoto" styleClass="btn, btn-secondary" text="Change Photo" style="-fx-font-size: 11px; -fx-padding: 4 10;" />
            </children>
        </VBox>
        
        <VBox spacing="15.0">
            <children>
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="text-p" text="Full Name" style="-fx-font-weight: bold;" />
                        <TextField fx:id="fullNameField" promptText="John Doe" styleClass="text-input" />
                    </children>
                </VBox>
                
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="text-p" text="Email Address" style="-fx-font-weight: bold;" />
                        <TextField fx:id="emailField" promptText="email@example.com" styleClass="text-input" />
                    </children>
                </VBox>
                
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="text-p" text="Phone Number" style="-fx-font-weight: bold;" />
                        <TextField fx:id="phoneField" promptText="+1234567890" styleClass="text-input" />
                    </children>
                </VBox>
                
                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="text-p" text="Password" style="-fx-font-weight: bold;" />
                        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-input" />
                    </children>
                </VBox>
                
                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="text-p" text="Role" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="text-input" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0" alignment="BOTTOM_LEFT" style="-fx-padding: 0 0 10 0;">
                            <children>
                                <CheckBox fx:id="isActiveCheckBox" text="Active Account" styleClass="text-p" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                
                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />
                
                <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button onAction="#handleCancel" styleClass="btn, btn-secondary" text="Cancel" />
                        <Button onAction="#handleSave" styleClass="btn, btn-primary" text="Save Changes" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
