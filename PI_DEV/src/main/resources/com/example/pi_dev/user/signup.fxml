<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.SignupController" stylesheets="@style.css">
    <content>
        <VBox alignment="CENTER" spacing="25.0">
            <padding>
                <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
            </padding>

            <VBox alignment="CENTER" spacing="8.0">
                <Label styleClass="text-h1" text="Create Account" />
                <Label styleClass="text-p" text="Join our community today" />
            </VBox>

            <VBox spacing="20.0" maxWidth="500.0" styleClass="card">
                <children>
                    <VBox alignment="CENTER" spacing="10.0">
                        <children>
                            <javafx.scene.shape.Circle fx:id="profileCircle" radius="50.0" fill="#F3F4F6" stroke="#E5E7EB" />
                            <Button onAction="#handleUploadPhoto" styleClass="btn, btn-secondary" text="Upload Photo" style="-fx-font-size: 12px; -fx-padding: 5 15;" />
                        </children>
                    </VBox>

                    <HBox spacing="15.0">
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="text-p" text="Full Name" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="fullNameField" promptText="John Doe" styleClass="text-input" />
                        </VBox>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="text-p" text="Email" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" promptText="john@example.com" styleClass="text-input" />
                        </VBox>
                    </HBox>

                    <HBox spacing="15.0">
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="text-p" text="Phone Number" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" promptText="+1234567890" styleClass="text-input" />
                        </VBox>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="text-p" text="I want to" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="text-input" />
                        </VBox>
                    </HBox>

                    <HBox spacing="15.0">
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="text-p" text="Password" style="-fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-input" />
                            <ProgressBar fx:id="strengthBar" maxWidth="Infinity" progress="0.0" prefHeight="12.0" styleClass="strength-bar" />
                            <Label fx:id="strengthLabel" style="-fx-font-size: 11px;" text="Strength: None" />
                        </VBox>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="text-p" text="Confirm Password" style="-fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="text-input" />
                        </VBox>
                    </HBox>

                    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />

                    <Button onAction="#handleSignup" styleClass="btn, btn-primary" text="Create Account" maxWidth="1.7976931348623157E308" />
                </children>
                <padding>
                    <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                </padding>
            </VBox>

            <HBox alignment="CENTER" spacing="5.0">
                <Label styleClass="text-p" text="Already have an account?" />
                <Hyperlink onAction="#goToLogin" text="Sign in" styleClass="nav-link" style="-fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
