<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.SignupController" stylesheets="@style.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label styleClass="label-title" text="Create Account" />
    <Label styleClass="label-subtitle" text="Join us today" />

    <VBox spacing="5" maxWidth="300">
        <Label text="Full Name" />
        <TextField fx:id="fullNameField" promptText="John Doe" />
    </VBox>

    <VBox spacing="5" maxWidth="300">
        <Label text="Email" />
        <TextField fx:id="emailField" promptText="john@example.com" />
    </VBox>

    <VBox spacing="5" maxWidth="300">
        <Label text="Phone Number" />
        <TextField fx:id="phoneField" promptText="+1234567890" />
    </VBox>

    <VBox spacing="5" maxWidth="300">
        <Label text="Role" />
        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" />
    </VBox>

    <VBox spacing="5" maxWidth="300">
        <Label text="Password" />
        <PasswordField fx:id="passwordField" promptText="Create a password" />
    </VBox>

    <VBox spacing="5" maxWidth="300">
        <Label text="Confirm Password" />
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" />
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-label" />

    <Button onAction="#handleSignup" styleClass="button-primary" text="Sign Up" maxWidth="300" />

    <Hyperlink onAction="#goToLogin" text="Already have an account? Login" />

</VBox>
