<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controllers.StatsDashboardController"
      spacing="20" style="-fx-background-color: #F5F5F5; -fx-padding: 20;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Back" onAction="#goBack"
                style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Label text="📊 Sales Dashboard"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
    </HBox>

    <!-- Stats Cards Row -->
    <HBox spacing="15">
        <!-- Total Revenue -->
        <VBox alignment="CENTER" spacing="5" prefWidth="150"
              style="-fx-background-color: #E8F5E9; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #A5D6A7; -fx-border-radius: 12;">
            <Label text="💰 Revenue" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <Label fx:id="totalRevenueLabel" text="0 TND"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
        </VBox>

        <!-- Total Orders -->
        <VBox alignment="CENTER" spacing="5" prefWidth="150"
              style="-fx-background-color: #E3F2FD; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #90CAF9; -fx-border-radius: 12;">
            <Label text="📦 Total Orders" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <Label fx:id="totalOrdersLabel" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        </VBox>

        <!-- Pending -->
        <VBox alignment="CENTER" spacing="5" prefWidth="150"
              style="-fx-background-color: #FFF8E1; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #FFE082; -fx-border-radius: 12;">
            <Label text="⏳ Pending" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <Label fx:id="pendingOrdersLabel" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E65100;"/>
        </VBox>

        <!-- Confirmed -->
        <VBox alignment="CENTER" spacing="5" prefWidth="150"
              style="-fx-background-color: #E8F5E9; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #A5D6A7; -fx-border-radius: 12;">
            <Label text="✅ Confirmed" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <Label fx:id="confirmedOrdersLabel" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
        </VBox>

        <!-- Cancelled -->
        <VBox alignment="CENTER" spacing="5" prefWidth="150"
              style="-fx-background-color: #FFEBEE; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #EF9A9A; -fx-border-radius: 12;">
            <Label text="❌ Cancelled" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <Label fx:id="cancelledOrdersLabel" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #C62828;"/>
        </VBox>

        <!-- Products -->
        <VBox alignment="CENTER" spacing="5" prefWidth="150"
              style="-fx-background-color: #F3E5F5; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #CE93D8; -fx-border-radius: 12;">
            <Label text="🛍 My Products" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <Label fx:id="totalProductsLabel" text="0"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6A1B9A;"/>
        </VBox>
    </HBox>

    <!-- Charts Row -->
    <HBox spacing="15">
        <!-- Revenue Chart -->
        <BarChart fx:id="revenueChart" prefWidth="450" prefHeight="280"
                  style="-fx-background-color: white; -fx-background-radius: 12;">
            <xAxis><CategoryAxis label="Date"/></xAxis>
            <yAxis><NumberAxis label="TND"/></yAxis>
        </BarChart>

        <!-- Pie Chart -->
        <PieChart fx:id="statusPieChart" prefWidth="300" prefHeight="280"
                  style="-fx-background-color: white; -fx-background-radius: 12;"/>
    </HBox>

    <!-- Top Products Chart -->
    <BarChart fx:id="topProductsChart" prefHeight="250"
              style="-fx-background-color: white; -fx-background-radius: 12;">
        <xAxis><CategoryAxis label="Product"/></xAxis>
        <yAxis><NumberAxis label="Units Sold"/></yAxis>
    </BarChart>

</VBox>
