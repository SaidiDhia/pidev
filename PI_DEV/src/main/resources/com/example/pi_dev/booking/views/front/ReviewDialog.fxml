<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pi_dev.Controllers.Front.ReviewDialogController"
      spacing="20"
      style="-fx-background-color: #FFFFFF;"
      minWidth="420" maxWidth="500">

    <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

    <!-- Header -->
    <VBox spacing="4">
        <Label text="⭐ Leave a Review"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Label text="Share your experience with other travellers."
               style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
    </VBox>

    <Separator opacity="0.3"/>

    <!-- Rating -->
    <VBox spacing="8">
        <Label text="Rating *"
               style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <ChoiceBox fx:id="ratingBox"
                   style="-fx-font-size: 14px; -fx-min-width: 120px;"/>
    </VBox>

    <!-- Comment -->
    <VBox spacing="8">
        <Label text="Comment (optional)"
               style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <TextArea fx:id="commentArea"
                  promptText="Write your thoughts about this place..."
                  prefHeight="110"
                  wrapText="true"
                  style="-fx-font-size: 13px;"/>
    </VBox>

    <!-- Error label -->
    <Label fx:id="errorLabel"
           text=""
           wrapText="true"
           style="-fx-text-fill: #DC2626; -fx-font-size: 12px;"/>

    <!-- AI Progress -->
    <ProgressIndicator fx:id="aiProgress"
                       visible="false"
                       managed="false"
                       prefWidth="32" prefHeight="32"/>

    <!-- AI Result Box (hidden initially, shown after analysis) -->
    <VBox fx:id="aiResultBox"
          visible="false"
          managed="false"
          spacing="8"
          style="-fx-background-color: #F0F9FF; -fx-background-radius: 10; -fx-border-color: #BAE6FD; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 14 16 14 16;">
        <Label text="🤖 AI Insights"
               style="-fx-font-weight: bold; -fx-text-fill: #0369A1; -fx-font-size: 13px;"/>
        <Label fx:id="sentimentLabel" text="" wrapText="false"/>
        <Label fx:id="aiSummaryLabel" text=""
               wrapText="true"
               style="-fx-text-fill: #374151; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel"
                style="-fx-background-color: transparent; -fx-border-color: #D1D5DB; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #374151; -fx-padding: 8 20 8 20; -fx-cursor: hand;"
                onAction="#handleCancel"/>
        <Button text="Submit Review"
                style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8 20 8 20; -fx-font-weight: bold; -fx-cursor: hand;"
                onAction="#handleSubmit"/>
    </HBox>

</VBox>
