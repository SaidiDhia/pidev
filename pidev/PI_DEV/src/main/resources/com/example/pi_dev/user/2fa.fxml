<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.TwoFactorController" stylesheets="@style.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label styleClass="label-title" text="Two-Factor Authentication" />
    <Label fx:id="instructionLabel" text="Scan the QR code below with your authenticator app" wrapText="true" maxWidth="300" textAlignment="CENTER"/>

    <!-- Placeholder for QR Code -->
    <VBox fx:id="qrContainer" alignment="CENTER" style="-fx-border-color: #ddd; -fx-border-width: 2; -fx-pref-width: 200; -fx-pref-height: 200;">
        <ImageView fx:id="qrCodeImage" fitWidth="200" fitHeight="200" preserveRatio="true" />
    </VBox>

    <!-- Placeholder for Webcam -->
    <VBox fx:id="faceContainer" alignment="CENTER" visible="false" managed="false" style="-fx-border-color: #ddd; -fx-border-width: 2; -fx-pref-width: 320; -fx-pref-height: 240;">
        <ImageView fx:id="webcamView" fitWidth="320" fitHeight="240" preserveRatio="true" />
    </VBox>

    <VBox fx:id="inputContainer" spacing="5" maxWidth="300">
        <Label text="Enter Verification Code" />
        <TextField fx:id="codeField" promptText="123456" alignment="CENTER" style="-fx-font-size: 18px;"/>
    </VBox>
    
    <Button fx:id="captureButton" onAction="#handleCapture" styleClass="button-primary" text="Capture Face" maxWidth="300" visible="false" managed="false"/>
    
    <Label fx:id="errorLabel" textFill="red" />

    <Button fx:id="verifyButton" onAction="#handleVerify" styleClass="button-primary" text="Verify" maxWidth="300" />
    
    <Button onAction="#goBack" styleClass="button-secondary" text="Cancel" maxWidth="300" />

</VBox>