<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.venue.controllers.HomeController">
   <top>
      <VBox spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 0, 5, 0, 0);" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label text="WonderLust" textFill="#ff385c">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 24; -fx-background-radius: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
                           <children>
                              <TextField fx:id="searchField" promptText="Start your search" style="-fx-background-color: transparent; -fx-prompt-text-fill: #666;">
                                 <font>
                                    <Font size="14.0" />
                                 </font>
                              </TextField>
                              <Button mnemonicParsing="false" style="-fx-background-color: #ff385c; -fx-background-radius: 24; -fx-text-fill: white;" text="Search">
                                 <HBox.margin>
                                    <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
                                 </HBox.margin>
                              </Button>
                           </children>
                           <padding>
                              <Insets bottom="4.0" left="16.0" right="4.0" top="4.0" />
                           </padding>
                        </HBox>
                     </children>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#handleBecomeHost" style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Become a Host" />
                  <Button fx:id="myPlacesButton" mnemonicParsing="false" onAction="#handleMyPlaces" style="-fx-background-color: transparent; -fx-text-fill: #333;" text="My Places" visible="false" managed="false" />
                  <Button fx:id="signInButton" mnemonicParsing="false" onAction="#handleSignIn" style="-fx-background-color: transparent; -fx-border-color: #ddd; -fx-border-radius: 24;" text="Sign In" />
                  <Button fx:id="settingsButton" mnemonicParsing="false" onAction="#handleSettings" style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Settings" />
                  <Button fx:id="adminButton" mnemonicParsing="false" onAction="#handleAdminDashboard" style="-fx-background-color: #333; -fx-text-fill: white; -fx-background-radius: 24;" text="Admin Dashboard" visible="false" managed="false" />
               </children>
               <padding>
                  <Insets bottom="16.0" left="48.0" right="48.0" top="16.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER" spacing="24.0">
               <children>
                  <Button style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Beachfront" />
                  <Button style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Cabins" />
                  <Button style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Trending" />
                  <Button style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Tiny homes" />
                  <Button style="-fx-background-color: transparent; -fx-text-fill: #333;" text="Campsites" />
                  <ToggleButton fx:id="mapViewToggle" mnemonicParsing="false" onAction="#handleMapViewToggle" text="Map View" />
               </children>
               <padding>
                  <Insets bottom="16.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <StackPane VBox.vgrow="ALWAYS" BorderPane.alignment="CENTER">
         <children>
            <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;">
               <content>
                  <FlowPane fx:id="placesContainer" hgap="24.0" vgap="40.0" prefWrapLength="1200.0">
                     <padding>
                        <Insets bottom="48.0" left="48.0" right="48.0" top="32.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
            <WebView fx:id="mapWebView" visible="false" />
         </children>
      </StackPane>
   </center>
</BorderPane>
