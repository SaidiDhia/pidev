<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.TwoFactorController" stylesheets="@style.css" styleClass="root">
    <padding>
        <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
    </padding>

    <VBox alignment="CENTER" spacing="8.0">
        <Label styleClass="text-h1" text="Two-Factor Authentication" />
        <Label fx:id="instructionLabel" styleClass="text-p" text="Secure your account with an extra layer of protection" wrapText="true" maxWidth="400" textAlignment="CENTER"/>
    </VBox>

    <VBox spacing="25.0" maxWidth="450.0" styleClass="card">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>
        <children>
            <!-- Placeholder for QR Code -->
            <VBox fx:id="qrContainer" alignment="CENTER" style="-fx-background-color: #F9FAFB; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1;">
                <ImageView fx:id="qrCodeImage" fitWidth="200" fitHeight="200" preserveRatio="true" />
            </VBox>

            <!-- Placeholder for Webcam -->
            <VBox fx:id="faceContainer" alignment="CENTER" visible="false" managed="false" style="-fx-background-color: black; -fx-background-radius: 12; -fx-overflow: hidden;">
                <ImageView fx:id="webcamView" fitWidth="320" fitHeight="240" preserveRatio="true" />
            </VBox>

            <VBox fx:id="inputContainer" spacing="12.0">
                <Label styleClass="text-p" text="Verification Code" style="-fx-font-weight: bold;" />
                <TextField fx:id="codeField" promptText="••••••" alignment="CENTER" styleClass="text-input" style="-fx-font-size: 24px; -fx-font-family: 'Monospaced'; -fx-letter-spacing: 5;"/>
            </VBox>
            
            <Button fx:id="captureButton" onAction="#handleCapture" styleClass="btn, btn-secondary" text="Capture Face" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
            
            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" alignment="CENTER" maxWidth="Infinity" />

            <VBox spacing="12.0">
                <Button fx:id="verifyButton" onAction="#handleVerify" styleClass="btn, btn-primary" text="Verify Identity" maxWidth="1.7976931348623157E308" />
                <Button onAction="#goBack" styleClass="btn, btn-secondary" text="Cancel" maxWidth="1.7976931348623157E308" />
            </VBox>
        </children>
    </VBox>
</VBox>