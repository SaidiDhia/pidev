<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" prefHeight="600" prefWidth="500" spacing="20" 
      style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -fx-padding: 30;" 
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.example.pi_dev.Controllers.Events.GoogleCalendarController">

   <children>
      <!-- Header -->
      <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: white;" text="📅 Google Calendar" />
      
      <!-- Status -->
      <VBox alignment="CENTER" spacing="15" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 20; -fx-background-radius: 15;">
         <children>
            <Label fx:id="statusLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #dc3545;" text="📅 Google Calendar Non Connecté" />
            
            <ProgressBar fx:id="progressBar" prefWidth="300" progress="0.0" visible="false" />
         </children>
      </VBox>
      
      <!-- Boutons d'action -->
      <VBox spacing="15" alignment="CENTER">
         <children>
            <Button fx:id="connectButton" onAction="#connectToGoogle" 
                    style="-fx-background-color: #4285f4; -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 15 30; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-width: 250;" 
                    text="🔑 Se connecter à Google Calendar" />
            
            <Button fx:id="testButton" onAction="#testConnection" 
                    style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 12 25; -fx-font-size: 14px; -fx-cursor: hand; -fx-pref-width: 250;" 
                    text="🔄 Tester la connexion" />
            
            <Button fx:id="syncButton" onAction="#syncReservations" disable="true"
                    style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 12 25; -fx-font-size: 14px; -fx-cursor: hand; -fx-pref-width: 250;" 
                    text="🔄 Synchroniser les réservations" />
         </children>
      </VBox>
      
      <!-- Informations -->
      <VBox fx:id="infoContainer" spacing="10" alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 15; -fx-background-radius: 10;">
         <children>
            <Label style="-fx-text-fill: white; -fx-font-style: italic;" text="Configurez la synchronisation avec votre Google Calendar pour ne jamais manquer un événement." />
         </children>
      </VBox>
      
      <!-- Bouton fermer -->
      <Button onAction="#close" 
              style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10 20; -fx-font-size: 14px; -fx-cursor: hand;" 
              text="❌ Fermer" />
   </children>
</VBox>
