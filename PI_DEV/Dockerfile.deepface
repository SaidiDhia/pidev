# DeepFace API
# Build from PI_DEV root:  docker build -f Dockerfile.deepface -t deepface-api .
# Run:  docker run -p 5000:5000 deepface-api
# Then the Java app can use Face ID by calling http://localhost:5000/verify

FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy entire deepface folder so /app has setup.py, deepface/, requirements, etc.
COPY deepface /app

# Install dependencies then install deepface from source
# tf-keras required for TensorFlow 2.20+
RUN pip install --no-cache-dir -r /app/requirements.txt \
    && pip install --no-cache-dir tf-keras \
    && pip install --no-cache-dir -e /app --no-deps

WORKDIR /app/deepface/api/src
EXPOSE 5000

# Auth is disabled if DEEPFACE_AUTH_TOKEN is not set
CMD ["gunicorn", "--workers=1", "--timeout=7200", "--bind=0.0.0.0:5000", "--log-level=info", "app:create_app()"]
