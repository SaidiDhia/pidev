<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pi_dev.Controllers.Booking.Front.MyBookingsController"
            stylesheets="@../../style.css">

    <VBox spacing="24" style="-fx-background-color: #F9FAFB; -fx-padding: 32 40 40 40;"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Header -->
        <VBox spacing="4">
            <Label styleClass="text-h1" text="My Bookings"/>
            <Label styleClass="section-subtitle" text="Manage your reservations"/>
        </VBox>

        <!-- Cards Container -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: #F9FAFB;">
            <FlowPane fx:id="bookingsFlowPane" hgap="24" vgap="24" style="-fx-padding: 10;">
                <!-- Cards will be injected here -->
            </FlowPane>
        </ScrollPane>

    </VBox>

</AnchorPane>