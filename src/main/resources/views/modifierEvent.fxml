<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="800.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-padding: 30;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.modifierEventController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" spacing="15">
         <children>
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #0F2C4F;" text="✏️ Modifier l'événement" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="retourButton" onAction="#goToCatalogue" style="-fx-background-color: #ffebee; -fx-text-fill: #cc6666; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10 20; -fx-font-size: 14px; -fx-cursor: hand;" text="❌ Retour" />
         </children>
      </HBox>
      
      <!-- Formulaire principal avec ScrollPane -->
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
         <content>
            <VBox maxWidth="900" spacing="30" style="-fx-padding: 20;">
               <children>
                  <HBox spacing="30" VBox.vgrow="ALWAYS">
                     <children>
                        <!-- Colonne gauche -->
                        <VBox spacing="15" HBox.hgrow="ALWAYS">
                           <children>
                              <!-- Nom de l'événement -->
                              <VBox spacing="5">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Nom de l'événement *" />
                                    <TextField fx:id="nomorgField" prefHeight="40" promptText="Entrez le nom de l'événement" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                              
                              <!-- Lieu -->
                              <VBox spacing="5">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Lieu *" />
                                    <TextField fx:id="lieuField" prefHeight="40" promptText="Lieu de l'événement" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                              
                              
                              <!-- Description -->
                              <VBox spacing="5">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Description" />
                                    <TextArea fx:id="descriptionField" prefHeight="60" promptText="Description détaillée de l'événement..." style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px; -fx-wrap-text: true;" />
                                 </children>
                              </VBox>
                              
                                                            
                              <!-- Dates -->
                              <HBox spacing="15">
                                 <children>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Date de début *" />
                                          <DatePicker fx:id="dateDebutPicker" prefHeight="40" promptText="Date de début" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Date de fin *" />
                                          <DatePicker fx:id="dateFinPicker" prefHeight="40" promptText="Date de fin" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              
                              <!-- Prix et capacité -->
                              <HBox spacing="15">
                                 <children>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Prix (TND) *" />
                                          <TextField fx:id="prixField" prefHeight="40" promptText="0.00" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Capacité max *" />
                                          <TextField fx:id="capaciteField" prefHeight="40" promptText="20" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              
                              <!-- Activité associée -->
                              <VBox spacing="5">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Activité associée" />
                                    <ComboBox fx:id="activiteCombo" prefHeight="40" prefWidth="400" promptText="Sélectionnez une activité" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                 </children>
                              </VBox>
                              
                              <!-- Email et téléphone -->
                              <HBox spacing="15">
                                 <children>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Email de l'organisateur *" />
                                          <TextField fx:id="emailField" prefHeight="40" promptText="email@exemple.com" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Téléphone de l'organisateur *" />
                                          <TextField fx:id="telephoneorgField" prefHeight="40" promptText="+216 XX XXX XXX" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              
                              <!-- Équipement nécessaire -->
                              <VBox spacing="5">
                                 <children>
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Équipement nécessaire" />
                                    <TextArea fx:id="equipementField" prefHeight="60" promptText="Listez l'équipement que les participants doivent apporter..." style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px; -fx-wrap-text: true;" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Section Médias et Informations complémentaires -->
                  <VBox spacing="25" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 30;">
                     <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="📸 Médias et informations" />
                        <Separator style="-fx-background-color: #e0e0e0;" />
                        
                        <!-- Image principale -->
                        <VBox spacing="10">
                           <children>
                              <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A4E85;" text="🖼️ Image principale de l'événement" />
                              <HBox spacing="15" alignment="CENTER_LEFT">
                                 <children>
                                    <ImageView fx:id="imagePrincipaleView" fitHeight="120" fitWidth="120" preserveRatio="true" style="-fx-border-color: #2D70B3; -fx-border-radius: 10; -fx-background-color: #f5f5f5;" />
                                    <VBox spacing="10">
                                       <children>
                                          <Button fx:id="importerImageButton" onAction="#importerImage" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 12 20; -fx-font-size: 14px; -fx-cursor: hand;" text="📷 Changer l'image" />
                                          <Label fx:id="imageStatusLabel" style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Image actuelle de l'événement" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        
                        <!-- Vidéo YouTube -->
                        <VBox spacing="10">
                           <children>
                              <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A4E85;" text="🎥 Vidéo YouTube (optionnel)" />
                              <TextField fx:id="videoYoutubeField" prefHeight="40" promptText="https://www.youtube.com/watch?v=..." style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12 16; -fx-font-size: 14px;" />
                           </children>
                        </VBox>
                        
                        <!-- Photos supplémentaires -->
                        <VBox spacing="10">
                           <children>
                              <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A4E85;" text="📷 Photos supplémentaires" />
                              <HBox fx:id="photosContainer" spacing="10" alignment="CENTER_LEFT" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-color: #f5f5f5; -fx-padding: 10;">
                                 <children>
                                    <Label style="-fx-font-size: 12px; -fx-text-fill: #666;" text="Aucune photo ajoutée" />
                                 </children>
                              </HBox>
                              <Button fx:id="ajouterPhotoButton" onAction="#ajouterPhoto" style="-fx-background-color: #e3f2fd; -fx-text-fill: #1976d2; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 10 20; -fx-font-size: 14px; -fx-cursor: hand;" text="📷 Ajouter une photo" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <!-- Boutons d'action -->
                  <HBox alignment="CENTER" spacing="20">
                     <children>
                        <Button fx:id="annulerButton" maxWidth="Infinity" onAction="#annulerEvent" style="-fx-background-color: #ffebee; -fx-text-fill: #cc6666; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 15 30; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="❌ Annuler" HBox.hgrow="ALWAYS" />
                        <Button fx:id="modifierEventButton" maxWidth="Infinity" onAction="#modifierEvent" style="-fx-background-color: linear-gradient(to bottom right, #1A4E85, #0F2C4F); -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 15 30; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="✏ Modifier l'événement" HBox.hgrow="ALWAYS" />
                        <Button fx:id="supprimerEventButton" maxWidth="Infinity" onAction="#supprimerEvent" style="-fx-background-color: linear-gradient(to bottom right, #d32f2f, #b71c1c); -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 15 30; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑 Supprimer l'événement" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>
