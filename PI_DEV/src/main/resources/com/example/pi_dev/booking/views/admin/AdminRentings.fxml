<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pi_dev.Controllers.Booking.Admin.AdminRentingsController"
      stylesheets="@../../style.css"
      spacing="20"
      style="-fx-background-color: white; -fx-padding: 24 32 32 32;">

    <VBox spacing="4">
        <Label styleClass="text-h2" text="Pending Place Approvals"/>
        <Label styleClass="section-subtitle" text="Review and approve or deny submitted place listings"/>
    </VBox>

    <TableView fx:id="placesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colTitle"   text="Title"       prefWidth="350"/>
            <TableColumn fx:id="colCity"    text="City"        prefWidth="200"/>
            <TableColumn fx:id="colPrice"   text="Price/Day"   prefWidth="120"/>
            <TableColumn fx:id="colStatus"  text="Status"      prefWidth="120"/>
            <TableColumn fx:id="colActions" text="Actions"     prefWidth="200"/>
        </columns>
        <placeholder>
            <Label styleClass="section-subtitle" text="No pending places."/>
        </placeholder>
    </TableView>

</VBox>