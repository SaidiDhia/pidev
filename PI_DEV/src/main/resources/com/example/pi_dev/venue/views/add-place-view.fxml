<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>

<AnchorPane prefHeight="750.0" prefWidth="900.0" stylesheets="@../../user/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.venue.controllers.AddPlaceController">
    <children>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-background-color: #F9FAFB;">
                    <padding>
                        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label styleClass="text-h1" text="List Your Space" />
                                <Label styleClass="text-p" text="Share your beautiful place with the world" style="-fx-text-fill: #6B7280;" />
                            </children>
                        </VBox>
                        
                        <VBox maxWidth="800.0" spacing="25.0" styleClass="card">
                            <padding>
                                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                            </padding>
                            <children>
                                <VBox spacing="8.0">
                                    <Label styleClass="text-p" text="Title" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="titleField" promptText="e.g., Cozy Mountain Cabin" styleClass="text-input" />
                                </VBox>
                                
                                <VBox spacing="8.0">
                                    <Label styleClass="text-p" text="Description" style="-fx-font-weight: bold;"/>
                                    <TextArea fx:id="descriptionArea" prefHeight="120.0" promptText="Describe what makes your place special..." styleClass="text-input" wrapText="true" />
                                </VBox>
                                
                                <HBox spacing="20.0">
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="text-p" text="Price per Day ($)" style="-fx-font-weight: bold;"/>
                                        <TextField fx:id="priceField" promptText="0.00" styleClass="text-input" />
                                    </VBox>
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="text-p" text="Capacity" style="-fx-font-weight: bold;"/>
                                        <TextField fx:id="capacityField" promptText="e.g. 2 Rooms" styleClass="text-input" />
                                    </VBox>
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="text-p" text="Max Guests" style="-fx-font-weight: bold;"/>
                                        <TextField fx:id="maxGuestsField" promptText="e.g. 4" styleClass="text-input" />
                                    </VBox>
                                </HBox>
                                
                                <HBox spacing="20.0">
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="text-p" text="Address" style="-fx-font-weight: bold;"/>
                                        <TextField fx:id="addressField" promptText="Street name and number" styleClass="text-input" />
                                    </VBox>
                                    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="text-p" text="City" style="-fx-font-weight: bold;"/>
                                        <TextField fx:id="cityField" promptText="City" styleClass="text-input" />
                                    </VBox>
                                </HBox>
                                
                                <VBox spacing="8.0">
                                    <Label styleClass="text-p" text="Category" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="categoryField" promptText="e.g. Apartment, House, Villa" styleClass="text-input" />
                                </VBox>

                                <VBox spacing="8.0">
                                    <Label styleClass="text-p" text="Amenities" style="-fx-font-weight: bold;"/>
                                    <javafx.scene.layout.FlowPane fx:id="amenitiesFlowPane" hgap="15.0" vgap="10.0" style="-fx-padding: 10; -fx-background-color: #F3F4F6; -fx-background-radius: 8;" />
                                </VBox>

                                <VBox spacing="15.0">
                                    <Label styleClass="text-p" text="Photos" style="-fx-font-weight: bold;"/>
                                    <HBox spacing="15" alignment="CENTER_LEFT">
                                        <Button text="Add Photos" onAction="#handleUploadPhoto" styleClass="btn" style="-fx-background-color: #F3F4F6; -fx-text-fill: #374151;"/>
                                        <Label fx:id="imagePathLabel" text="No photos selected" styleClass="text-p" style="-fx-text-fill: #6B7280;"/>
                                    </HBox>
                                    <ScrollPane fitToHeight="true" prefHeight="160.0" style="-fx-background-color: transparent;" vbarPolicy="NEVER">
                                        <content>
                                            <HBox fx:id="imagePreviewContainer" spacing="10.0" style="-fx-padding: 5;">
                                                <!-- Multiple ImageViews will be added here -->
                                            </HBox>
                                        </content>
                                    </ScrollPane>
                                </VBox>
                                
                                <VBox spacing="12.0">
                                    <Label styleClass="text-p" text="Location" style="-fx-font-weight: bold;"/>
                                    <HBox spacing="20.0">
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <Label text="Latitude" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                                            <TextField fx:id="latitudeField" promptText="Latitude" styleClass="text-input" />
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <Label text="Longitude" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                                            <TextField fx:id="longitudeField" promptText="Longitude" styleClass="text-input" />
                                        </VBox>
                                    </HBox>
                                    <Label text="Click on the map to set location" styleClass="text-p" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                                    <WebView fx:id="mapWebView" prefHeight="400.0" prefWidth="600.0" styleClass="card" />
                                </VBox>

                                <HBox spacing="20.0" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
                                    <Button mnemonicParsing="false" onAction="#handleBack" styleClass="btn" style="-fx-background-color: transparent; -fx-text-fill: #6B7280;" text="Cancel" />
                                    <Button mnemonicParsing="false" onAction="#handleSubmit" prefWidth="200.0" styleClass="btn, btn-primary" text="Submit Listing" />
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
