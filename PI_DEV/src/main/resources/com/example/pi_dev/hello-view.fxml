<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0"
      style="-fx-background-color: linear-gradient(to bottom, #EFF6FF, #ffffff); -fx-padding: 40;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pi_dev.HelloController">
    <children>
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Label text="WonderLust" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;"/>
                <Label text="Choose what you want to do today"
                       style="-fx-font-size: 16px; -fx-text-fill: #2563eb;"/>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="30.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0"
                      style="-fx-background-color: white; -fx-padding: 20 30; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(37,99,235,0.12), 12, 0, 0, 6);">
                    <children>
                        <Label text="Create an Event"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;"/>
                        <Label text="Plan activities and adventures for your guests"
                               style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>
                        <Button text="Create Event"
                                onAction="#onCreateEvent"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 24; -fx-font-size: 14px; -fx-cursor: hand;"/>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="10.0"
                      style="-fx-background-color: white; -fx-padding: 20 30; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(37,99,235,0.12), 12, 0, 0, 6);">
                    <children>
                        <Label text="Sign In"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;"/>
                        <Label text="Access your account and settings"
                               style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>
                        <Button text="Sign In"
                                onAction="#onRentPlace"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 24; -fx-font-size: 14px; -fx-cursor: hand;"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
