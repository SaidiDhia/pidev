<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.PaymentController"
            stylesheets="@/css/style.css" styleClass="root">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            <Button fx:id="backButton" text="← Back" styleClass="btn-back" onAction="#goBack"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="topTitle" text="💳  Secure Payment" styleClass="page-title">
                <font><Font name="System Bold" size="20"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="topAmount" text=""
                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#2E7D32;"/>
        </HBox>
    </top>

    <center>

        <!-- ═══════════════════════════════════════════════════
             FORM PANEL — shown first, hidden after Pay clicked
             ═══════════════════════════════════════════════════ -->
        <ScrollPane fx:id="formPanel" fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="22" alignment="TOP_CENTER">
                <padding><Insets top="30" right="100" bottom="30" left="100"/></padding>

                <!-- AMOUNT BANNER -->
                <VBox spacing="6" alignment="CENTER"
                      style="-fx-background-color:linear-gradient(to right,#1a1a2e,#16213e);-fx-background-radius:15;-fx-padding:30;">
                    <Label text="Amount Due"
                           style="-fx-text-fill:rgba(255,255,255,0.65);-fx-font-size:13px;"/>
                    <Label fx:id="amountLabel" text="0.000 TND"
                           style="-fx-text-fill:white;-fx-font-size:44px;-fx-font-weight:bold;"/>
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="🔒" style="-fx-font-size:11px;"/>
                        <Label text="Powered by Stripe — 256-bit SSL encryption"
                               style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:11px;"/>
                    </HBox>
                </VBox>

                <!-- BILLING DETAILS -->
                <VBox spacing="14"
                      style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#E0E0E0;-fx-border-radius:12;-fx-padding:24;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="👤" style="-fx-font-size:18px;"/>
                        <Label text="Billing Details"
                               style="-fx-font-size:15px;-fx-font-weight:bold;"/>
                    </HBox>
                    <Separator/>

                    <GridPane hgap="15" vgap="5">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="First Name *"
                                   style="-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <TextField fx:id="firstNameField" promptText="Mohamed"
                                       style="-fx-background-radius:8;-fx-border-color:#BDBDBD;-fx-border-radius:8;-fx-padding:10;-fx-font-size:13px;"/>
                            <Label fx:id="firstNameError" text="⚠  Required"
                                   style="-fx-text-fill:#E53935;-fx-font-size:11px;"
                                   visible="false" managed="false"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Last Name *"
                                   style="-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <TextField fx:id="lastNameField" promptText="Ben Ali"
                                       style="-fx-background-radius:8;-fx-border-color:#BDBDBD;-fx-border-radius:8;-fx-padding:10;-fx-font-size:13px;"/>
                            <Label fx:id="lastNameError" text="⚠  Required"
                                   style="-fx-text-fill:#E53935;-fx-font-size:11px;"
                                   visible="false" managed="false"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1"
                              GridPane.columnSpan="2">
                            <padding><Insets top="8"/></padding>
                            <Label text="Email Address *"
                                   style="-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <TextField fx:id="emailField" promptText="example@email.com"
                                       style="-fx-background-radius:8;-fx-border-color:#BDBDBD;-fx-border-radius:8;-fx-padding:10;-fx-font-size:13px;"/>
                            <Label fx:id="emailError" text="⚠  Enter a valid email address"
                                   style="-fx-text-fill:#E53935;-fx-font-size:11px;"
                                   visible="false" managed="false"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- PAY BUTTON -->
                <Button fx:id="payButton" text="💳  Pay with Stripe"
                        onAction="#initiateStripePayment" maxWidth="Infinity"
                        style="-fx-background-color:#635BFF;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:18;-fx-font-size:17px;-fx-font-weight:bold;-fx-cursor:hand;-fx-effect:dropshadow(gaussian,rgba(99,91,255,0.4),14,0,0,4);"/>

                <Label text="🔒  Your card details are entered directly on Stripe. We never see them."
                       wrapText="true" alignment="CENTER"
                       style="-fx-text-fill:#999;-fx-font-size:11px;"/>
            </VBox>
        </ScrollPane>

    </center>

</BorderPane>
