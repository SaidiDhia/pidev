<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pi_dev.marketplace.Controllers.ProductAvailableController"
            stylesheets="@../css/style.css"
            styleClass="root">

    <!-- Top Bar with Navigation -->
    <top>
        <HBox spacing="15"
              alignment="CENTER"
              styleClass="top-bar">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Button text="🏠 Products"
                    styleClass="nav-btn"
                    onAction="#goToProductManagement"/>

            <Button text="📝 Invoices"
                    styleClass="nav-btn"
                    onAction="#goToFactureList"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Available Products"
                   styleClass="page-title">
                <font>
                    <Font name="System Bold" size="20"/>
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="cartBadge"
                   text="🛒 0"
                   styleClass="badge"
                   onMouseClicked="#goToCart"
                   style="-fx-cursor: hand;"/>

            <Button text="Refresh"
                    styleClass="btn-secondary"
                    onAction="#refresh"/>

        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    styleClass="scroll-pane">

            <VBox spacing="20">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Products Grid -->
                <FlowPane fx:id="productFlow"
                          hgap="20"
                          vgap="20"
                          alignment="TOP_LEFT"
                          prefWrapLength="1000"/>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
