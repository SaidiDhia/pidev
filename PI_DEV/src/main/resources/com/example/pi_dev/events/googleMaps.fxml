<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="800.0" spacing="15.0" 
      style="-fx-background-color: linear-gradient(to bottom, #f8f9fa, #e9ecef); -fx-padding: 20;" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.example.pi_dev.Controllers.Events.GoogleMapsController">
    
    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label fx:id="titleLabel" text="🗺️ Google Maps - Localisation d'Événements" 
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <Button fx:id="closeButton" onAction="#close" text="✖" 
                        style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 50; -fx-pref-width: 40; -fx-pref-height: 40; -fx-font-size: 16px; -fx-font-weight: bold;" />
            </children>
        </HBox>
        
        <!-- Status Bar -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8;">
            <children>
                <Label fx:id="statusLabel" text="🗺️ Google Maps Non Connecté" 
                       style="-fx-font-weight: bold; -fx-text-fill: #dc3545;" />
                <Pane HBox.hgrow="ALWAYS" />
                <ProgressBar fx:id="progressBar" prefWidth="200.0" visible="false" />
            </children>
        </HBox>
        
        <!-- Search Section -->
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
            <children>
                <Label text="🔍 Recherche de Localisation" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="searchField" prefWidth="300.0" promptText="Entrez une adresse ou un lieu..." 
                                  style="-fx-background-radius: 5; -fx-border-color: #ced4da; -fx-border-radius: 5;" />
                        <Button fx:id="searchButton" onAction="#searchLocation" text="🔍 Rechercher" 
                                style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 120;" />
                        <Button fx:id="showMapButton" onAction="#showMap" text="🗺️ Carte" 
                                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 100;" />
                    </children>
                </HBox>
            </children>
        </VBox>
        
        <!-- Nearby Places Section -->
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
            <children>
                <Label text="🏪 Lieux à Proximité" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Localisation:" style="-fx-font-weight: bold;" />
                        <TextField fx:id="locationField" prefWidth="200.0" promptText="Adresse de base..." 
                                  style="-fx-background-radius: 5; -fx-border-color: #ced4da; -fx-border-radius: 5;" />
                    </children>
                </HBox>
                
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Type:" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="placeTypeComboBox" prefWidth="150.0" 
                                  style="-fx-background-radius: 5; -fx-border-color: #ced4da; -fx-border-radius: 5;" />
                        
                        <Label text="Rayon:" style="-fx-font-weight: bold;" />
                        <Slider fx:id="radiusSlider" prefWidth="150.0" />
                        <Label fx:id="radiusLabel" text="Rayon: 1000 m" style="-fx-text-fill: #6c757d;" />
                    </children>
                </HBox>
                
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="findNearbyButton" onAction="#findNearbyPlaces" text="🔍 Rechercher à proximité" 
                                style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 180;" />
                        <Button fx:id="getDirectionsButton" onAction="#getDirections" text="🧭 Itinéraire" 
                                style="-fx-background-color: #6f42c1; -fx-text-fill: white; -fx-background-radius: 5; -fx-pref-width: 120;" />
                    </children>
                </HBox>
            </children>
        </VBox>
        
        <!-- Map and Results -->
        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Map View -->
                <VBox spacing="10.0" prefWidth="400.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <children>
                        <Label text="🗺️ Carte" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                        
                        <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
                            <content>
                                <ImageView fx:id="mapImageView" preserveRatio="true" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
                
                <!-- Results -->
                <VBox spacing="10.0" prefWidth="350.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                    <children>
                        <Label text="📋 Résultats" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                        
                        <ScrollPane fx:id="resultsScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="resultsContainer" spacing="10.0" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <!-- Control Buttons -->
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="testConnectionButton" onAction="#testConnection" text="🔄 Tester la connexion" 
                        style="-fx-background-color: #ffc107; -fx-text-fill: #212529; -fx-background-radius: 5; -fx-pref-width: 150; -fx-font-weight: bold;" />
            </children>
        </HBox>
        
    </children>
</VBox>
