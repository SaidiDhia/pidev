<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.PaymentController"
            stylesheets="@/css/style.css" styleClass="root" minHeight="650">

    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
            <Button text="← Back" styleClass="btn-back" onAction="#goBack"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="💳  Secure Payment — Stripe" styleClass="page-title">
                <font><Font name="System Bold" size="20"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="22" alignment="TOP_CENTER">
                <padding><Insets top="25" right="80" bottom="25" left="80"/></padding>

                <!-- AMOUNT BANNER -->
                <VBox spacing="6" alignment="CENTER"
                      style="-fx-background-color:linear-gradient(to right,#1a1a2e,#16213e);-fx-background-radius:15;-fx-padding:28;">
                    <Label text="Amount Due" style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:13px;"/>
                    <Label fx:id="amountLabel" text="0.000 TND"
                           style="-fx-text-fill:white;-fx-font-size:42px;-fx-font-weight:bold;"/>
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="🔒" style="-fx-font-size:11px;"/>
                        <Label text="Powered by Stripe — 256-bit SSL encryption"
                               style="-fx-text-fill:rgba(255,255,255,0.55);-fx-font-size:11px;"/>
                    </HBox>
                </VBox>

                <!-- TEST CARD INFO -->
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color:#FFF8E1;-fx-background-radius:10;-fx-border-color:#FFB300;-fx-border-radius:10;-fx-padding:14;">
                    <Label text="🧪" style="-fx-font-size:20px;"/>
                    <VBox spacing="3">
                        <Label text="TEST MODE — No real money charged"
                               style="-fx-font-weight:bold;-fx-text-fill:#7B4F00;-fx-font-size:13px;"/>
                        <Label text="Card: 4242 4242 4242 4242   |   Expiry: 12/26   |   CVC: 123   |   ZIP: 12345"
                               style="-fx-text-fill:#7B4F00;-fx-font-size:12px;-fx-font-family:monospace;"/>
                    </VBox>
                </HBox>

                <!-- BILLING DETAILS -->
                <VBox spacing="14" style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#E0E0E0;-fx-border-radius:12;-fx-padding:22;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="👤" style="-fx-font-size:18px;"/>
                        <Label text="Billing Details" style="-fx-font-size:15px;-fx-font-weight:bold;"/>
                    </HBox>
                    <Separator/>

                    <GridPane hgap="15" vgap="5">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="First Name *" style="-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <TextField fx:id="firstNameField" promptText="Mohamed"
                                       style="-fx-background-radius:8;-fx-border-color:#BDBDBD;-fx-border-radius:8;-fx-padding:10;-fx-font-size:13px;"/>
                            <Label fx:id="firstNameError" text="⚠ Required"
                                   style="-fx-text-fill:#E53935;-fx-font-size:11px;" visible="false" managed="false"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Last Name *" style="-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <TextField fx:id="lastNameField" promptText="Ben Ali"
                                       style="-fx-background-radius:8;-fx-border-color:#BDBDBD;-fx-border-radius:8;-fx-padding:10;-fx-font-size:13px;"/>
                            <Label fx:id="lastNameError" text="⚠ Required"
                                   style="-fx-text-fill:#E53935;-fx-font-size:11px;" visible="false" managed="false"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <padding><Insets top="8"/></padding>
                            <Label text="Email Address * (Stripe sends receipt here)"
                                   style="-fx-font-weight:bold;-fx-font-size:13px;"/>
                            <TextField fx:id="emailField" promptText="example@email.com"
                                       style="-fx-background-radius:8;-fx-border-color:#BDBDBD;-fx-border-radius:8;-fx-padding:10;-fx-font-size:13px;"/>
                            <Label fx:id="emailError" text="⚠ Enter a valid email address"
                                   style="-fx-text-fill:#E53935;-fx-font-size:11px;" visible="false" managed="false"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- HOW IT WORKS -->
                <VBox spacing="10" style="-fx-background-color:white;-fx-background-radius:12;-fx-border-color:#E0E0E0;-fx-border-radius:12;-fx-padding:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <Label text="ℹ️  How it works" style="-fx-font-size:14px;-fx-font-weight:bold;"/>
                    <Separator/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="1️⃣" style="-fx-font-size:16px;"/>
                        <Label text="Click Pay → your browser opens Stripe's secure checkout automatically"
                               style="-fx-font-size:12px;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="2️⃣" style="-fx-font-size:16px;"/>
                        <Label text="Enter the test card above and confirm payment"
                               style="-fx-font-size:12px;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="3️⃣" style="-fx-font-size:16px;"/>
                        <Label text="This app detects payment automatically — no button needed"
                               style="-fx-font-size:12px;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="4️⃣" style="-fx-font-size:16px;"/>
                        <Label text="Order confirmed + stock updated only if payment succeeds ✅"
                               style="-fx-font-size:12px;-fx-text-fill:#2E7D32;-fx-font-weight:bold;"/>
                    </HBox>
                </VBox>

                <!-- WAITING BOX -->
                <VBox fx:id="waitingBox" spacing="14" visible="false" managed="false" alignment="CENTER"
                      style="-fx-background-color:#E8EAF6;-fx-background-radius:12;-fx-border-color:#3F51B5;-fx-border-radius:12;-fx-padding:25;">
                    <Label text="🌐  Stripe Checkout opened in your browser"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#283593;"/>
                    <Label fx:id="waitingLabel" text="⏳  Waiting for payment confirmation..."
                           style="-fx-text-fill:#3F51B5;-fx-font-size:13px;"/>
                    <Label text="Complete payment in your browser. This page updates automatically."
                           wrapText="true" alignment="CENTER"
                           style="-fx-text-fill:#555;-fx-font-size:12px;"/>
                    <ProgressBar progress="-1" maxWidth="Infinity" style="-fx-accent:#3F51B5;"/>
                    <Button text="✖  Cancel Payment" onAction="#goBack"
                            style="-fx-background-color:transparent;-fx-text-fill:#E53935;-fx-border-color:#E53935;-fx-border-radius:8;-fx-background-radius:8;-fx-padding:8 20;-fx-cursor:hand;"/>
                </VBox>

                <!-- PAY BUTTON -->
                <Button fx:id="payButton" text="💳  Pay with Stripe"
                        onAction="#initiateStripePayment" maxWidth="Infinity"
                        style="-fx-background-color:#635BFF;-fx-text-fill:white;-fx-background-radius:12;-fx-padding:18;-fx-font-size:17px;-fx-font-weight:bold;-fx-cursor:hand;-fx-effect:dropshadow(gaussian,rgba(99,91,255,0.4),12,0,0,4);"/>

                <Label text="🔒  Payments processed securely by Stripe. Your card details never touch our server."
                       wrapText="true" alignment="CENTER"
                       style="-fx-text-fill:#999;-fx-font-size:11px;"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
