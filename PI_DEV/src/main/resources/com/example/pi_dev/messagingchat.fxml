<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.MenuButton?>
    <?import javafx.scene.control.MenuItem?>
<VBox fx:id="mainContainer" style="-fx-background-color: linear-gradient(to bottom, #f0f8f0, #ffffff); -fx-padding: 0;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.pi_dev.messaging.messagecontroller.ChatController">

    <children>
        <!-- ==================== HEADER SECTION ==================== -->
        <HBox fx:id="headerBox" alignment="CENTER_LEFT" style="-fx-background-color: #1a5f3f; -fx-padding: 20; -fx-spacing: 20;">
            <children>
                <!-- Logo as text emoji -->
                <Label fx:id="logoLabel" style="-fx-font-size: 40px; -fx-text-fill: white;" text="💬" />

                <!-- Title -->
                <VBox fx:id="titleBox" spacing="5">
                    <children>
                        <Label fx:id="mainTitle" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Wanderlust Chat" />
                        <Label fx:id="subTitle" style="-fx-font-size: 14px; -fx-text-fill: #90ee90;" text="Connect with fellow adventurers" />
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Theme Toggle Button -->
                <HBox fx:id="themeButtonBox" alignment="CENTER" spacing="15">
                    <children>
                        <Button fx:id="themeBtn"
                                onAction="#toggleTheme"
                                style="-fx-background-color: #2d7a2d; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 8 16; -fx-font-size: 16px; -fx-cursor: hand;"
                                text="🌙" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- ==================== SEARCH AND ACTIONS BAR ==================== -->
        <HBox fx:id="searchBar" spacing="20" style="-fx-background-color: white; -fx-padding: 15 40; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" alignment="CENTER">
            <children>
                <Label fx:id="searchIcon" style="-fx-font-size: 20px; -fx-text-fill: #2d7a2d;" text="🔍" />
                <TextField fx:id="conversationSearchField"
                           promptText="Search conversations..."
                           style="-fx-border-color: #5cb85c; -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 10 20; -fx-font-size: 14px; -fx-pref-width: 300;"
                           HBox.hgrow="ALWAYS" />
                <Button fx:id="newChatButton" onAction="#handleCreateConversation"
                        style="-fx-background-color: #2d7a2d; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10 24; -fx-font-size: 14px; -fx-cursor: hand;"
                        text="➕ New Chat" />
            </children>
        </HBox>

        <!-- ==================== MAIN CONTENT ==================== -->
        <TabPane fx:id="mainTabPane" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <tabs>
                <!-- ==================== CHAT TAB ==================== -->
                <Tab fx:id="chatTab" closable="false" text="💬 Messages">
                    <content>
                        <BorderPane fx:id="chatBorderPane" style="-fx-background-color: #f8faf8; -fx-padding: 20;">

                            <!-- LEFT: Conversations Panel -->
                            <left>
                                <VBox fx:id="leftPanel" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e0e0e0; -fx-padding: 15;" prefWidth="300">
                                    <children>
                                        <!-- Conversations Header -->
                                        <Label fx:id="conversationsHeader" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a5f3f;" text="Your Conversations"/>

                                        <!-- Conversations List -->
                                        <ListView fx:id="conversationList"
                                                  VBox.vgrow="ALWAYS"
                                                  style="-fx-background-color: transparent; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8;">
                                            <placeholder>
                                                <Label style="-fx-text-fill: #999; -fx-padding: 20;" text="No conversations yet. Start a new one!"/>
                                            </placeholder>
                                        </ListView>
                                    </children>
                                </VBox>
                            </left>

                            <!-- CENTER: Messages Panel -->
                            <center>
                                <VBox fx:id="centerPanel" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e0e0e0; -fx-padding: 20;">
                                    <BorderPane.margin>
                                        <Insets left="20"/>
                                    </BorderPane.margin>
                                    <children>
                                        <!-- Conversation Header with Actions -->
                                        <HBox fx:id="conversationHeaderBox" alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f0f8f0; -fx-background-radius: 8; -fx-padding: 12;">
                                            <children>
                                                <Label fx:id="headerIcon" style="-fx-font-size: 18px; -fx-text-fill: #1a5f3f;" text="💬" />
                                                <Label fx:id="conversationTitleLabel"
                                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d7a2d;"
                                                       text="Select a conversation"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <!-- Update/Delete buttons for selected conversation -->
                                                <Button fx:id="updateConversationBtn"
                                                        onAction="#handleUpdateConversation"
                                                        style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 15; -fx-font-size: 12px; -fx-cursor: hand; -fx-opacity: 0.9;"
                                                        text="✏️ Rename"
                                                        visible="false"/>
                                                <Button fx:id="deleteConversationBtn"
                                                        onAction="#handleDeleteConversation"
                                                        style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 15; -fx-font-size: 12px; -fx-cursor: hand; -fx-opacity: 0.9;"
                                                        text="🗑️ Delete"
                                                        visible="false"/>
                                            </children>
                                        </HBox>

                                        <!-- Messages List -->
                                        <ScrollPane fx:id="messageScrollPane"
                                                    fitToWidth="true"
                                                    VBox.vgrow="ALWAYS"
                                                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                            <content>
                                                <ListView fx:id="messageList"
                                                          style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                                    <placeholder>
                                                        <VBox fx:id="messagePlaceholder" alignment="CENTER" spacing="10">
                                                            <padding>
                                                                <Insets top="40" right="40" bottom="40" left="40"/>
                                                            </padding>
                                                            <Label fx:id="placeholderIcon" style="-fx-font-size: 24px;" text="💭"/>
                                                            <Label fx:id="placeholderText" style="-fx-text-fill: #999; -fx-font-size: 14px;" text="No messages yet. Start the conversation!"/>
                                                        </VBox>
                                                    </placeholder>
                                                </ListView>
                                            </content>
                                        </ScrollPane>

                                        <HBox fx:id="messageInputContainer" spacing="5" style="-fx-background-color: #f0f8f0; -fx-background-radius: 30; -fx-padding: 5 10;" alignment="CENTER">
                                            <children>
                                                <MenuButton fx:id="attachMenuBtn"
                                                            style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand;"
                                                            text="📎">
                                                    <items>
                                                        <MenuItem text="📷 Image" onAction="#handleAttachImage"/>
                                                        <MenuItem text="🎥 Video" onAction="#handleAttachVideo"/>
                                                        <MenuItem text="🎵 Audio File" onAction="#handleAttachAudio"/>
                                                        <MenuItem text="📎 File" onAction="#handleAttachFile"/>
                                                    </items>
                                                </MenuButton>

                                                <!-- Voice recording button -->
                                                <Button fx:id="voiceRecordBtn"
                                                        style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-text-fill: black;"
                                                        text="🎤"
                                                        onAction="#toggleVoiceRecording"/>

                                                <!-- NEW: AI Smart Reply Button -->
                                                <Button fx:id="smartReplyBtn"
                                                        style="-fx-background-color: #2d7a2d; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 5 12; -fx-font-size: 13px; -fx-cursor: hand;"
                                                        text="🤖 Smart Reply"
                                                        onAction="#handleSmartReply"/>

                                                <!-- Recording indicator (initially hidden) -->
                                                <HBox fx:id="recordingIndicator" spacing="5" alignment="CENTER" visible="false" managed="false">
                                                    <Label text="🔴" style="-fx-text-fill: red; -fx-font-size: 16px;"/>
                                                    <Label text="Recording..." style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                                                    <Label fx:id="recordingTimeLabel" text="0:00" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                                                    <Button fx:id="stopRecordingBtn"
                                                            text="⬛"
                                                            style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-background-radius: 15; -fx-min-width: 30; -fx-min-height: 30; -fx-cursor: hand;"
                                                            onAction="#stopVoiceRecording"/>
                                                    <Button fx:id="cancelRecordingBtn"
                                                            text="✖"
                                                            style="-fx-background-color: #999; -fx-text-fill: white; -fx-background-radius: 15; -fx-min-width: 30; -fx-min-height: 30; -fx-cursor: hand;"
                                                            onAction="#cancelVoiceRecording"/>
                                                </HBox>

                                                <TextField fx:id="messageInput"
                                                           promptText="Type a message..."
                                                           HBox.hgrow="ALWAYS"
                                                           style="-fx-border-color: #5cb85c; -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 10 15; -fx-font-size: 14px;"/>

                                                <Button fx:id="sendButton" onAction="#sendMessage"
                                                        style="-fx-background-color: #2d7a2d; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10 20; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"
                                                        text="Send"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </center>
                        </BorderPane>
                    </content>
                </Tab>
                <!-- ==================== ARCHIVED CHATS TAB ==================== -->
                <Tab fx:id="archivedTab" closable="false" text="📦 Archived">
                    <content>
                        <VBox style="-fx-background-color: #f8faf8; -fx-padding: 20;" spacing="15">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to bottom right, #6c757d, #495057); -fx-background-radius: 12; -fx-padding: 20;">
                                    <children>
                                        <Label style="-fx-font-size: 24px; -fx-text-fill: white;" text="📦" />
                                        <VBox spacing="5">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="Archived Conversations" />
                                                <Label style="-fx-font-size: 14px; -fx-text-fill: #adb5bd;" text="Conversations you've hidden" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="unarchiveAllBtn"
                                                text="Unarchive All"
                                                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 16;"/>
                                    </children>
                                </HBox>

                                <ListView fx:id="archivedConversationList" VBox.vgrow="ALWAYS">
                                    <placeholder>
                                        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 40;">
                                            <Label style="-fx-font-size: 32px;" text="📭"/>
                                            <Label style="-fx-text-fill: #999; -fx-font-size: 14px;" text="No archived conversations"/>
                                            <Label style="-fx-text-fill: #999; -fx-font-size: 12px;" text="Archive conversations to hide them from your main list"/>
                                        </VBox>
                                    </placeholder>
                                </ListView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                <!-- ==================== CONTACTS TAB ==================== -->
                <Tab fx:id="contactsTab" closable="false" text="👥 Contacts">
                    <content>
                        <VBox fx:id="contactsContainer" style="-fx-background-color: #f8faf8;" spacing="20">
                            <padding>
                                <Insets top="30" right="30" bottom="30" left="30"/>
                            </padding>
                            <children>
                                <HBox fx:id="contactsHeader" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to bottom right, #2d7a2d, #1a5f3f); -fx-background-radius: 12; -fx-padding: 20;">
                                    <children>
                                        <Label fx:id="contactsIcon" style="-fx-font-size: 24px; -fx-text-fill: white;" text="👥" />
                                        <VBox fx:id="contactsTitleBox" spacing="5">
                                            <children>
                                                <Label fx:id="contactsTitle" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="Your Contacts" />
                                                <Label fx:id="contactsSubtitle" style="-fx-font-size: 14px; -fx-text-fill: #90ee90;" text="Connect with fellow adventurers" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <ScrollPane fx:id="contactsScrollPane"
                                            fitToWidth="true"
                                            hbarPolicy="NEVER"
                                            VBox.vgrow="ALWAYS"
                                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                    <content>
                                        <FlowPane fx:id="contactsFlow"
                                                  hgap="20"
                                                  vgap="20">
                                            <padding>
                                                <Insets top="10" right="10" bottom="10" left="10"/>
                                            </padding>
                                            <!-- Contacts will be added dynamically by the controller -->
                                        </FlowPane>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>

        <!-- ==================== FOOTER SECTION ==================== -->
        <HBox fx:id="footerBox" alignment="CENTER" style="-fx-background-color: #1a5f3f; -fx-padding: 20; -fx-border-color: #2d7a2d; -fx-border-width: 2 0 0 0;">
            <children>
                <VBox fx:id="footerText" alignment="CENTER" spacing="5">
                    <children>
                        <Label fx:id="footerTitle" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="🌍 Wanderlust Chat" />
                        <Label fx:id="footerSubtitle" style="-fx-font-size: 12px; -fx-text-fill: #90ee90;" text="Connect with travelers and adventurers" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox fx:id="footerContacts" alignment="CENTER" spacing="20">
                    <children>
                        <Label fx:id="footerEmail" style="-fx-font-size: 12px; -fx-text-fill: #90ee90;" text="📧 chat@wanderlust.tn" />
                        <Label fx:id="footerSupport" style="-fx-font-size: 12px; -fx-text-fill: #90ee90;" text="💬 24/7 Support" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </children>
</VBox>