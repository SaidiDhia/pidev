<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.AdminDashboardController">
    <top>
        <VBox styleClass="navbar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="25.0">
                    <children>
                        <Label styleClass="text-h2" text="WonderLust Admin" style="-fx-text-fill: #4F46E5;" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="15.0">
                            <children>
                                <Button onAction="#handleBackToHome" styleClass="btn, btn-secondary" text="View Site" />
                                <Button onAction="#handleSettings" styleClass="btn, btn-secondary" text="Settings" />
                                <Button onAction="#handleLogout" styleClass="btn, btn-danger" text="Logout" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="25.0" style="-fx-background-color: #F9FAFB;">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab text="Users Management">
                            <VBox spacing="20.0" style="-fx-padding: 25 0 0 0;">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="card" style="-fx-padding: 5 15; -fx-background-radius: 8;">
                                                <children>
                                                    <TextField fx:id="searchField" prefWidth="300.0" promptText="Search users by name or email..." style="-fx-background-color: transparent;" />
                                                </children>
                                            </HBox>
                                            <ComboBox fx:id="roleFilter" prefWidth="180.0" promptText="Filter by Role" />
                                            <Button onAction="#handleResetFilters" styleClass="btn, btn-secondary" text="Reset Filters" />
                                            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Button onAction="#handleAddUser" styleClass="btn, btn-primary" text="+ Add New User" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </HBox>
                                    
                                    <VBox styleClass="card" VBox.vgrow="ALWAYS">
                                        <children>
                                            <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="colAvatar" prefWidth="60.0" text="PHOTO" />
                                                    <TableColumn fx:id="colName" prefWidth="180.0" text="FULL NAME" />
                                                    <TableColumn fx:id="colEmail" prefWidth="220.0" text="EMAIL ADDRESS" />
                                                    <TableColumn fx:id="colPhone" prefWidth="140.0" text="PHONE" />
                                                    <TableColumn fx:id="colRole" prefWidth="120.0" text="ROLE" />
                                                    <TableColumn fx:id="colStatus" prefWidth="100.0" text="STATUS" />
                                                    <TableColumn fx:id="colActions" prefWidth="180.0" text="ACTIONS" />
                                                </columns>
                                                <columnResizePolicy>
                                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                </columnResizePolicy>
                                            </TableView>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </Tab>
                        
                        <Tab text="Venue Requests">
                            <VBox spacing="20.0" style="-fx-padding: 25 0 0 0;">
                                <children>
                                    <VBox spacing="8.0">
                                        <children>
                                            <Label styleClass="text-h2" text="Venue Requests" />
                                            <Label styleClass="text-p" text="Review and manage venue listing requests" style="-fx-text-fill: #6B7280;" />
                                        </children>
                                    </VBox>
                                    
                                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                        <content>
                                            <FlowPane fx:id="venueRequestsFlowPane" hgap="20.0" vgap="20.0" style="-fx-padding: 10;">
                                                <!-- Cards will be added here dynamically -->
                                            </FlowPane>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </Tab>

                        <Tab text="All Places">
                            <VBox spacing="20.0" style="-fx-padding: 25 0 0 0;">
                                <children>
                                    <VBox spacing="8.0">
                                        <children>
                                            <Label styleClass="text-h2" text="Platform Places" />
                                            <Label styleClass="text-p" text="Manage all existing venues on the platform" style="-fx-text-fill: #6B7280;" />
                                        </children>
                                    </VBox>
                                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                        <content>
                                            <FlowPane fx:id="allPlacesFlowPane" hgap="20.0" vgap="20.0" style="-fx-padding: 10;">
                                                <!-- Cards will be added here dynamically -->
                                            </FlowPane>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </Tab>

                        <Tab text="Reservations">
                            <VBox spacing="20.0" style="-fx-padding: 25 0 0 0;">
                                <children>
                                    <VBox spacing="8.0">
                                        <children>
                                            <Label styleClass="text-h2" text="All Reservations" />
                                            <Label styleClass="text-p" text="Monitor all bookings across the platform" style="-fx-text-fill: #6B7280;" />
                                        </children>
                                    </VBox>
                                    
                                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                        <content>
                                            <FlowPane fx:id="reservationsFlowPane" hgap="20.0" vgap="20.0" style="-fx-padding: 10;">
                                                <!-- Cards will be added here dynamically -->
                                            </FlowPane>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </Tab>

                        <Tab text="Activity Log">
                            <VBox spacing="20.0" style="-fx-padding: 25 0 0 0;">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                                        <children>
                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label styleClass="text-h2" text="Platform Activity" />
                                                    <Label styleClass="text-p" text="Real-time notifications of system events and user actions" style="-fx-text-fill: #6B7280;" />
                                                </children>
                                            </VBox>
                                            <Button onAction="#loadActivityLogs" styleClass="btn, btn-secondary" text="Refresh Logs" />
                                        </children>
                                    </HBox>
                                    
                                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                        <content>
                                            <VBox fx:id="activityLogContainer" spacing="12.0" style="-fx-padding: 10;">
                                                <!-- Notification cards will be added here dynamically -->
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </Tab>
                    </tabs>
                </TabPane>
            </children>
        </VBox>
    </center>
</BorderPane>