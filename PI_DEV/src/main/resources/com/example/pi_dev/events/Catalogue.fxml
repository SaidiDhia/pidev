<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane style="-fx-background-color: transparent; -fx-border-color: transparent;" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" prefHeight="800" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.events.Controllers.catalogueController">
    <content>
        <VBox style="-fx-background-color: linear-gradient(to bottom, #CAD4DC, #ffffff); -fx-padding: 0;" prefWidth="1200">
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to bottom right, #86A7BF, #2D70B3); -fx-padding: 20; -fx-spacing: 20;">
            <children>
                <ImageView fitHeight="84.0" fitWidth="92.0">
                    <image>
                        <Image url="@../images/wanderlust-logo.png" />
                    </image>
                </ImageView>
                <VBox spacing="5">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Wanderlust" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #0F2C4F;" text="Catalogue des aventures tunisiennes" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Button style="-fx-background-color: #1A4E85; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 16; -fx-font-size: 14px; -fx-cursor: hand;" text="🌿 Catalogue" />
                    </children>
                </HBox>
            </children>
        </HBox>
        
        <!-- Widget météo dans le catalogue -->
        <VBox style="-fx-background-color: white; -fx-padding: 20 40; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-text-fill: #1A4E85;" text="🌤️" />
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0F2C4F;" text="Conditions météo actuelles" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="refreshWeather" onAction="#refreshWeather" style="-fx-background-color: #86A7BF; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 16; -fx-font-size: 12px; -fx-cursor: hand;" text="🔄 Actualiser" />
                    </children>
                </HBox>
                <VBox fx:id="weatherWidgetContainer" style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-padding: 15; -fx-margin-top: 10;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B; -fx-font-weight: bold;" text="🌍 Ville:" />
                                <ComboBox fx:id="cityComboBox" prefWidth="150" style="-fx-border-color: #2D70B3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 14px;" />
                                <Button fx:id="refreshWeatherButton" onAction="#refreshWeather" style="-fx-background-color: #2D70B3; -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8 16; -fx-font-size: 12px; -fx-cursor: hand;" text="🔄 Actualiser" />
                            </children>
                        </HBox>
                        <VBox fx:id="weatherInfoContainer" style="-fx-background-color: transparent; -fx-padding: 10;">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B; -fx-alignment: center;" text="Chargement des données météo..." />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
        
        <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 25 40; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <children>
                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-text-fill: #1A4E85;" text="🔍" />
                        <TextField fx:id="txtRecherche" onAction="#handleRecherche" promptText="Rechercher une activité, un lieu..." style="-fx-border-color: #2D70B3; -fx-border-radius: 25; -fx-background-radius: 25; -fx-padding: 12 20; -fx-font-size: 14px; -fx-pref-width: 300;" />
                        <Button fx:id="recherche" onAction="#handleRecherche" style="-fx-background-color: #1A4E85; -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 12 24; -fx-font-size: 14px; -fx-cursor: hand;" text="Rechercher" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="orgactivite" onAction="#ouvrirGestionActivites" prefWidth="180" style="-fx-background-color: #2D70B3; -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 12 24; -fx-font-size: 14px; -fx-cursor: hand;" text="📋ajouter activités" />
                        <Button fx:id="orgevent" onAction="#ouvrirOrganisation" prefWidth="200" style="-fx-background-color: linear-gradient(to bottom right, #86A7BF, #2D70B3); -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 12 24; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="🎯 Voulez-vous organiser ?" />
                        <Button fx:id="googleCalendarBtn" onAction="#ouvrirGoogleCalendar" prefWidth="180" style="-fx-background-color: #4285f4; -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 12 24; -fx-font-size: 14px; -fx-cursor: hand;" text="📅 Google Calendar" />
                        <Button fx:id="googleMapsBtn" onAction="#ouvrirGoogleMaps" prefWidth="180" style="-fx-background-color: #34a853; -fx-text-fill: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-padding: 12 24; -fx-font-size: 14px; -fx-cursor: hand;" text="🗺️ Google Maps" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="15" />
            </children>
        </VBox>
        <TabPane style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <tabs>
                <Tab fx:id="tabActivites" closable="false" text="🌱 Activités">
                    <content>
                        <VBox style="-fx-background-color: #f8faf8; -fx-padding: 30;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to bottom right, #1A4E85, #0F2C4F); -fx-background-radius: 12; -fx-padding: 20; ">
                                    <children>
                                        <Label style="-fx-font-size: 24px; -fx-text-fill: white;" text="🏃‍♂️" />
                                        <VBox spacing="5">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="Nos Activités Outdoor" />
                                                <Label style="-fx-font-size: 14px; -fx-text-fill: #0F2C4F;" text="Vivez des expériences uniques au cœur de la nature tunisienne" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <FlowPane fx:id="flowActivites" hgap="20" style="-fx-background-color: transparent; -fx-padding: 10;" vgap="20" prefWidth="1100" minHeight="400">
                                    <!-- Les cards d'activités seront ajoutées dynamiquement par le contrôleur -->
                                </FlowPane>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                <Tab fx:id="tabEvents" closable="false" text="📅 Événements">
                    <content>
                        <VBox style="-fx-background-color: #f8faf8; -fx-padding: 30;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to bottom right, #2D70B3, #1A4E85); -fx-background-radius: 12; -fx-padding: 20; ">
                                    <children>
                                        <Label style="-fx-font-size: 24px; -fx-text-fill: white;" text="🎉" />
                                        <VBox spacing="5">
                                            <children>
                                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="Événements Spéciaux" />
                                                <Label style="-fx-font-size: 14px; -fx-text-fill: #CAD4DC;" text="Participez à nos événements thématiques et festivals" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                                <FlowPane fx:id="flowEvents" hgap="20" style="-fx-background-color: transparent; -fx-padding: 10;" vgap="20" prefWidth="1100" minHeight="400">
                                    <!-- Les cards d'événements seront ajoutées dynamiquement par le contrôleur -->
                                </FlowPane>
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
        <HBox alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #86A7BF, #2D70B3); -fx-padding: 20; -fx-border-color: #1A4E85; -fx-border-width: 2 0 0 0;">
            <children>
                <VBox alignment="CENTER" spacing="5">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="🌍 Wanderlust Tunisia" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #CAD4DC;" text="Votre partenaire pour des aventures inoubliables en Tunisie" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #CAD4DC;" text="📧 contact@wanderlust.tn" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #CAD4DC;" text="📱 +216 95 594 003" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </children>
</VBox>
    </content>
</ScrollPane>
