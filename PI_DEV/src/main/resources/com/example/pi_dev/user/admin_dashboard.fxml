<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.AdminDashboardController" stylesheets="@style.css">
    <top>
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button text="&lt; Back to Home" onAction="#handleBackToHome" styleClass="button-secondary"/>
                <Label text="Admin Dashboard" styleClass="label-title"/>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="10">
                    <Button text="Settings" onAction="#handleSettings" styleClass="button-secondary"/>
                    <Button text="Logout" onAction="#handleLogout" style="-fx-text-fill: red;" styleClass="button-secondary"/>
                </HBox>
            </HBox>
        </VBox>
    </top>
    
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Users Management">
                    <VBox spacing="10" style="-fx-padding: 15;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField" promptText="Search by name..." prefWidth="250"/>
                            <ComboBox fx:id="roleFilter" promptText="Filter by Role" prefWidth="150"/>
                            <Button text="Reset" onAction="#handleResetFilters" styleClass="button-secondary"/>
                            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                <Button text="+ Add User" onAction="#handleAddUser" styleClass="button-primary"/>
                            </HBox>
                        </HBox>
                        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colName" text="Full Name" prefWidth="150"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                                <TableColumn fx:id="colPhone" text="Phone" prefWidth="120"/>
                                <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                                <TableColumn fx:id="colStatus" text="Status" prefWidth="80"/>
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </Tab>
                <Tab text="Venue Requests">
                    <VBox spacing="10" style="-fx-padding: 15;">
                        <Label text="Pending Venue Requests" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <TableView fx:id="pendingPlacesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="titleColumn" prefWidth="200.0" text="Title" />
                                <TableColumn fx:id="hostColumn" prefWidth="150.0" text="Host ID" />
                                <TableColumn fx:id="priceColumn" prefWidth="100.0" text="Price/Day" />
                                <TableColumn fx:id="actionColumn" prefWidth="200.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</BorderPane>