<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pi_dev.user.controllers.LoginController" stylesheets="@style.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label styleClass="label-title" text="Welcome Back" />
    <Label styleClass="label-subtitle" text="Sign in to continue" />

    <VBox spacing="5" maxWidth="300">
        <Label text="Email" />
        <TextField fx:id="emailField" promptText="Enter your email" />
    </VBox>

    <VBox spacing="5" maxWidth="300">
        <Label text="Password" />
        <PasswordField fx:id="passwordField" promptText="Enter your password" />
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-label" />

    <Button onAction="#handleLogin" styleClass="button-primary" text="Login" maxWidth="300" />

    <Hyperlink onAction="#goToSignup" text="Don't have an account? Sign up" />
    <Hyperlink onAction="#goToForgotPassword" text="Forgot Password?" />

</VBox>
