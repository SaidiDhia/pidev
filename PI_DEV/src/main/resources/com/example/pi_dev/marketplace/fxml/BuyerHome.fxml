<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pi_dev.marketplace.Controllers.ProductAvailableController"
            stylesheets="@/com/example/pi_dev/marketplace/css/example/pi_dev/marketplace/css/style.css">

    <!-- TOP NAV — Buyer only -->
    <top>
        <VBox style="-fx-background-color: #2E7D32;">

            <!-- Nav Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT"
                  style="-fx-padding: 12 20; -fx-background-color: #2E7D32;">

                <!-- Back to role selection -->
                <Button text="⬅ Home" onAction="#goToRoleSelection"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 14; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Label text="🌿 WonderLust — Buyer"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Nav buttons -->


                <Button text="📋 My Orders" onAction="#goToFactureList"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 16; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Label fx:id="cartBadge" text="🛒 My Cart (0)"
                       onMouseClicked="#goToCart"
                       style="-fx-background-color: rgba(255,255,255,0.15);
              -fx-text-fill: white;
              -fx-background-radius: 20;
              -fx-padding: 6 16;
              -fx-cursor: hand;
              -fx-font-weight: bold;
              -fx-font-size: 13px;"/>
            </HBox>

            <!-- Search and Filter Bar -->
            <HBox spacing="12" alignment="CENTER"
                  style="-fx-padding: 10 20; -fx-background-color: #1B5E20;">

                <!-- Search -->
                <TextField fx:id="searchField"
                           promptText="🔍 Search products..."
                           onKeyReleased="#handleSearch"
                           prefWidth="280"
                           style="-fx-background-radius: 20; -fx-padding: 8 15;
                                  -fx-font-size: 13px;"/>

                <!-- Category Filter -->
                <ComboBox fx:id="categoryFilter"
                          promptText="📂 All Categories"
                          onAction="#handleFilter"
                          prefWidth="160"
                          style="-fx-background-radius: 20;"/>

                <!-- Type Filter -->
                <ComboBox fx:id="typeFilter"
                          promptText="🏷️ All Types"
                          onAction="#handleFilter"
                          prefWidth="140"
                          style="-fx-background-radius: 20;"/>

                <!-- Price Sort -->
                <ComboBox fx:id="sortFilter"
                          promptText="💰 Sort by Price"
                          onAction="#handleSort"
                          prefWidth="150"
                          style="-fx-background-radius: 20;"/>

                <Button text="🔄 Reset" onAction="#resetFilters"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 8 16; -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="🔃 Refresh" onAction="#refresh"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </top>

    <!-- Products Grid -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true">
            <VBox spacing="20">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <FlowPane fx:id="productFlow" hgap="20" vgap="20"
                          alignment="TOP_LEFT" prefWrapLength="1000"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
