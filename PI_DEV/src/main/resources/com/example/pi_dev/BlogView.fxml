<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.pi_dev.blog.Controllers.BlogController"
            style="-fx-background-color: #EFF6FF;">

    <top>
        <HBox style="-fx-background-color:#1E40AF; -fx-padding:0 32 0 32; -fx-alignment:CENTER_LEFT; -fx-spacing:0; -fx-min-height:58; -fx-effect:dropshadow(gaussian,rgba(30,64,175,0.25),10,0,0,3);">
            <children>
                <Label text="✦ Wanderlust" style="-fx-font-size:19px; -fx-font-weight:bold; -fx-text-fill:#FFFFFF; -fx-font-family:'Segoe UI',Arial;"/>
                <Label text="  Blog" style="-fx-font-size:19px; -fx-font-weight:300; -fx-text-fill:#BFDBFE; -fx-font-family:'Segoe UI',Arial;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="navArchiveBtn" text="🗂  Sauvegardés" onAction="#handleShowArchive"
                        style="-fx-background-color:rgba(255,255,255,0.12); -fx-background-radius:8; -fx-text-fill:#FFFFFF; -fx-font-size:13px; -fx-font-family:'Segoe UI',Arial; -fx-padding:8 16 8 16; -fx-cursor:HAND; -fx-border-color:rgba(255,255,255,0.2); -fx-border-radius:8;"/>
                <Separator orientation="VERTICAL" style="-fx-padding:12 16 12 16;"/>
                <HBox spacing="8" style="-fx-alignment:CENTER_LEFT; -fx-padding:0 0 0 8;">
                    <children>
                        <Label text="●" style="-fx-text-fill:#86EFAC; -fx-font-size:9px;"/>
                        <Label fx:id="currentUsernameLabel" text="Utilisateur" style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#FFFFFF; -fx-font-family:'Segoe UI',Arial;"/>
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <children>
                <!-- MAIN FEED -->
                <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            style="-fx-background:transparent; -fx-background-color:transparent; -fx-border-color:transparent;">
                    <content>
                        <VBox alignment="TOP_CENTER" style="-fx-background-color:#EFF6FF;">
                            <padding><Insets top="28" bottom="48" left="20" right="20"/></padding>
                            <children>
                                <VBox fx:id="feedColumn" maxWidth="700" minWidth="340" spacing="0" style="-fx-alignment:TOP_CENTER;">

                                    <!-- CREATE POST CARD -->
                                    <VBox style="-fx-background-color:#FFFFFF; -fx-background-radius:14; -fx-effect:dropshadow(gaussian,rgba(30,64,175,0.08),16,0,0,2); -fx-padding:20 22 20 22; -fx-spacing:14;">
                                        <VBox.margin><Insets bottom="20"/></VBox.margin>
                                        <children>
                                            <HBox spacing="12" style="-fx-alignment:CENTER_LEFT;">
                                                <children>
                                                    <Label text="✎" style="-fx-background-color:linear-gradient(to bottom right, #1E40AF, #3B82F6);
 -fx-background-radius:22; -fx-min-width:42; -fx-min-height:42; -fx-max-width:42; -fx-max-height:42; -fx-alignment:CENTER; -fx-text-fill:white; -fx-font-size:17px;"/>
                                                    <VBox spacing="1">
                                                        <children>
                                                            <Label text="Créer une publication" style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#111827; -fx-font-family:'Segoe UI',Arial;"/>
                                                            <Label text="Partagez vos pensées avec la communauté" style="-fx-font-size:11px; -fx-text-fill:#9CA3AF; -fx-font-family:'Segoe UI',Arial;"/>
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>

                                            <TextArea fx:id="newPostContent" promptText="Quoi de neuf ?" wrapText="true" prefRowCount="4"
                                                      style="-fx-font-size:13px; -fx-font-family:'Segoe UI',Arial; -fx-text-fill:#374151; -fx-background-color:#F8FAFF; -fx-background-radius:10; -fx-border-color:#BFDBFE; -fx-border-radius:10; -fx-border-width:1.5; -fx-padding:11;"/>

                                            <Label fx:id="postErrorLabel" visible="false" managed="false" style="-fx-text-fill:#EF4444; -fx-font-size:11px; -fx-font-family:'Segoe UI',Arial;"/>

                                            <HBox spacing="8" style="-fx-alignment:CENTER_LEFT;">
                                                <children>
                                                    <TextField fx:id="newPostMediaPath" promptText="Photo ou vidéo (optionnel)" HBox.hgrow="ALWAYS"
                                                               style="-fx-font-size:12px; -fx-font-family:'Segoe UI',Arial; -fx-background-color:#F8FAFF; -fx-background-radius:8; -fx-border-color:#BFDBFE; -fx-border-radius:8; -fx-border-width:1.5; -fx-padding:8 12 8 12;"/>
                                                    <Button text="📎" onAction="#handleBrowseMedia" style="-fx-background-color:#EFF6FF; -fx-background-radius:8; -fx-text-fill:#1E40AF; -fx-font-size:14px; -fx-min-width:36; -fx-min-height:36; -fx-cursor:HAND; -fx-border-color:#BFDBFE; -fx-border-radius:8;"/>
                                                </children>
                                            </HBox>

                                            <HBox spacing="10" style="-fx-alignment:CENTER_LEFT;">
                                                <children>
                                                    <Label text="Visibilité :" style="-fx-font-size:12px; -fx-text-fill:#6B7280; -fx-font-family:'Segoe UI',Arial;"/>
                                                    <ComboBox fx:id="visibilityCombo" style="-fx-font-size:12px; -fx-background-color:#EFF6FF; -fx-background-radius:8; -fx-border-color:#BFDBFE; -fx-border-radius:8;"/>
                                                    <Region HBox.hgrow="ALWAYS"/>
                                                    <Button text="Effacer" onAction="#handleClearPost" style="-fx-background-color:transparent; -fx-text-fill:#9CA3AF; -fx-font-size:12px; -fx-padding:8 14 8 14; -fx-cursor:HAND;"/>
                                                    <Button fx:id="publishBtn" text="Publier" onAction="#handlePublishPost"
                                                            style="-fx-background-color:#1E40AF; -fx-background-radius:9; -fx-text-fill:white; -fx-font-size:12px; -fx-font-weight:bold; -fx-padding:8 20 8 20; -fx-cursor:HAND;"/>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <!-- FEED HEADER -->
                                    <HBox spacing="8" style="-fx-alignment:CENTER_LEFT; -fx-padding:0 0 10 2;">
                                        <children>
                                            <Label text="Publications" style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#1E40AF; -fx-font-family:'Segoe UI',Arial;"/>
                                            <Label fx:id="postCountLabel" text="· 0 publications" style="-fx-font-size:13px; -fx-text-fill:#9CA3AF; -fx-font-family:'Segoe UI',Arial;"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button text="↻" onAction="#handleRefresh" style="-fx-background-color:transparent; -fx-text-fill:#1E40AF; -fx-font-size:16px; -fx-cursor:HAND; -fx-border-color:transparent;"/>
                                        </children>
                                    </HBox>

                                    <VBox fx:id="postsFeedContainer" spacing="14"/>
                                    <VBox fx:id="emptyStateBox" alignment="CENTER" spacing="10" visible="false" managed="false" style="-fx-padding:60 0 60 0;">
                                        <children>
                                            <Label text="✦" style="-fx-font-size:44px; -fx-text-fill:#BFDBFE;"/>
                                            <Label text="Aucune publication" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#9CA3AF; -fx-font-family:'Segoe UI',Arial;"/>
                                            <Label text="Soyez le premier à partager quelque chose !" style="-fx-font-size:12px; -fx-text-fill:#D1D5DB; -fx-font-family:'Segoe UI',Arial;"/>
                                        </children>
                                    </VBox>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- ARCHIVE VIEW -->
                <VBox fx:id="archiveView" visible="false" managed="false" style="-fx-background-color:#EFF6FF;">
                    <children>
                        <HBox style="-fx-background-color:#1E40AF; -fx-padding:14 28 14 28; -fx-alignment:CENTER_LEFT; -fx-spacing:14; -fx-effect:dropshadow(gaussian,rgba(30,64,175,0.2),8,0,0,2);">
                            <children>
                                <Button text="← Retour au fil" onAction="#handleShowFeed"
                                        style="-fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:8; -fx-text-fill:#FFFFFF; -fx-font-size:13px; -fx-cursor:HAND; -fx-border-color:rgba(255,255,255,0.25); -fx-border-radius:8; -fx-padding:6 14 6 14;"/>
                                <Label text="Publications sauvegardées" style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#FFFFFF; -fx-font-family:'Segoe UI',Arial;"/>
                                <Label fx:id="archiveCountLabel" text="· 0 sauvegardé(s)" style="-fx-font-size:13px; -fx-text-fill:#BFDBFE; -fx-font-family:'Segoe UI',Arial;"/>
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                                    style="-fx-background:transparent; -fx-background-color:transparent; -fx-border-color:transparent;">
                            <content>
                                <VBox alignment="TOP_CENTER" style="-fx-background-color:#EFF6FF;">
                                    <padding><Insets top="24" bottom="48" left="20" right="20"/></padding>
                                    <children>
                                        <VBox fx:id="archiveFeedContainer" maxWidth="700" minWidth="340" spacing="14" style="-fx-alignment:TOP_CENTER;"/>
                                        <VBox fx:id="archiveEmptyBox" alignment="CENTER" spacing="10" visible="false" managed="false" style="-fx-padding:60 0 0 0;">
                                            <children>
                                                <Label text="🗂" style="-fx-font-size:44px;"/>
                                                <Label text="Aucune publication sauvegardée" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#9CA3AF;"/>
                                                <Label text="Sauvegardez des publications depuis le fil pour les retrouver ici." style="-fx-font-size:12px; -fx-text-fill:#D1D5DB;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

</BorderPane>
