<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.ProductDetailsController"
            style="-fx-background-color: #F0F4F0;">

    <!-- TOP BAR — copied from BuyerHome.fxml -->
    <top>
        <VBox style="-fx-background-color: #2E7D32;">

            <!-- Nav Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT"
                  style="-fx-padding: 12 20; -fx-background-color: #2E7D32;">

                <Button text="⬅ Home" onAction="#goToRoleSelection"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 14; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Label text="🌿 WonderLust — Buyer"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="📋 My Orders" onAction="#goToOrders"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-background-radius: 20;
                               -fx-padding: 6 16; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Label fx:id="cartBadge" text="🛒 My Cart (0)"
                       onMouseClicked="#goToCart"
                       style="-fx-background-color: rgba(255,255,255,0.15);
                              -fx-text-fill: white;
                              -fx-background-radius: 20;
                              -fx-padding: 6 16;
                              -fx-cursor: hand;
                              -fx-font-weight: bold;
                              -fx-font-size: 13px;"/>
            </HBox>

        </VBox>
    </top>

    <!-- Content -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #F0F4F0; -fx-background: #F0F4F0;">
            <VBox spacing="24">
                <padding><Insets top="24" right="50" bottom="40" left="50"/></padding>

                <!-- Back button -->
                <Button text="← Back to Products" onAction="#goBack"
                        style="-fx-background-color: white;
                               -fx-text-fill: #2E7D32;
                               -fx-border-color: #2E7D32;
                               -fx-border-radius: 20;
                               -fx-background-radius: 20;
                               -fx-padding: 7 18;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-font-size: 12px;"/>

                <!-- Two column layout -->
                <HBox spacing="24" alignment="TOP_LEFT">

                    <!-- Left: Info Card -->
                    <VBox spacing="18" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 16;
                                 -fx-border-color: #E8E8E8;
                                 -fx-border-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                        <!-- Image + Title -->
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <ImageView fx:id="productImage"
                                       fitWidth="200" fitHeight="180"
                                       preserveRatio="true"
                                       style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);"/>
                            <VBox spacing="10" alignment="TOP_LEFT" HBox.hgrow="ALWAYS">
                                <Label fx:id="titleLabel" text="" wrapText="true"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label fx:id="typeLabel" text=""/>
                                    <Label fx:id="categoryLabel" text=""
                                           style="-fx-background-color: #F5F5F5; -fx-text-fill: #666;
                                                  -fx-background-radius: 10; -fx-padding: 3 10; -fx-font-size: 12px;"/>
                                </HBox>
                            </VBox>
                        </HBox>

                        <Separator/>

                        <VBox spacing="8">
                            <Label text="About this product"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                            <Label fx:id="descriptionLabel" text="" wrapText="true"
                                   style="-fx-text-fill: #666; -fx-font-size: 13px;"/>
                        </VBox>

                        <Separator/>

                        <HBox>
                            <VBox spacing="5" alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="PRICE" style="-fx-text-fill: #AAA; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <Label fx:id="priceLabel" text=""
                                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox spacing="5" alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="AVAILABILITY" style="-fx-text-fill: #AAA; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <Label fx:id="stockLabel" text="" style="-fx-font-size: 12px;"/>
                            </VBox>
                            <Separator orientation="VERTICAL"/>
                            <VBox spacing="5" alignment="CENTER" HBox.hgrow="ALWAYS">
                                <Label text="LISTED ON" style="-fx-text-fill: #AAA; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <Label fx:id="dateLabel" text="" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Right: Order Card -->
                    <VBox spacing="16" minWidth="250" maxWidth="260"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 16;
                                 -fx-border-color: #E8E8E8;
                                 -fx-border-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);">
                        <padding><Insets top="24" right="20" bottom="24" left="20"/></padding>

                        <Label text="Order" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Separator/>

                        <VBox spacing="6">
                            <Label text="Quantity" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                            <Spinner fx:id="quantitySpinner" min="1" max="100"
                                     initialValue="1" editable="true"
                                     maxWidth="1.7976931348623157E308"/>
                        </VBox>

                        <Button fx:id="addToCartBtn" text="🛒  Add to Cart"
                                onAction="#addToCart"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #2E7D32;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-padding: 13 0;
                                       -fx-font-size: 14px;
                                       -fx-cursor: hand;"/>

                        <Separator/>
                        <Label text="✅  Secure checkout" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                        <Label text="🔄  Easy returns"    style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                        <Label text="🚚  Fast delivery"   style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
